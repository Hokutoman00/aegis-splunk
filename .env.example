# Aegis hackathon — environment template (2026-05-09 pivoted to TF integration)
# Copy to .env.local and fill in. Never commit .env.local.

# === TrueFoundry tenant (required, Criteria #1) ===
TRUEFOUNDRY_BASE_URL=https://aegis-hackathon.truefoundry.cloud
TRUEFOUNDRY_API_KEY=
# Get key from: TF dashboard → Settings → API Keys
TRUEFOUNDRY_VIRTUAL_MODEL=aegis-resilient
# Virtual model name configured in TF dashboard with fallback chain

# === LLM provider keys (registered in TF Integrations, Aegis goes through TF) ===
# These get pasted into TF dashboard → Integrations once, then Aegis uses TF API only
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Local fallback (still client-side)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# === Chaos injector controls (Aegis 自作 layer) ===
# All default off. Set to "on" or probability (0.0-1.0) to enable specific failure modes.
CHAOS_PRIMARY_DOWN=
CHAOS_MCP_ERROR_RATE=
CHAOS_ALL_LLM_DOWN=
CHAOS_TOOL_PARTIAL=

# === Telemetry (Aegis UI pulls from TF AI Monitoring) ===
TF_OBSERVABILITY_ENDPOINT=
# Get from: TF dashboard → AI Monitoring → API access

# === Server ===
PORT=3000
NODE_ENV=development

# === Splunk hosted models (Phase 1 — additional provider for hedge/fallback) ===
# Splunk AI Assistant exposes gpt-oss-120b / gpt-oss-20b / foundation-ai-security
# over an OpenAI-compatible chat-completions surface on the Splunk management port.
SPLUNK_HOSTED_MODELS_BASE=https://localhost:8089/services/ai
# Session token from /services/auth/login or a long-lived service account token.
SPLUNK_SESSION_TOKEN=
# HEC (HTTP Event Collector) — used by later phases for receipt / telemetry shipping.
SPLUNK_HEC_URL=https://localhost:8088/services/collector
SPLUNK_HEC_TOKEN=
# Splunk MCP Server (Splunkbase #7931) — primary upstream for the MCP proxy.
# On primary failure, the proxy falls back to a REST shim that talks to
# SPLUNK_HOSTED_MODELS_BASE-derived endpoints (e.g. /services/search/jobs).
SPLUNK_MCP_URL=http://localhost:8089/services/mcp
